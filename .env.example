# API Configuration
# Change this to your backend API URL
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Application Configuration
VITE_APP_NAME=Ecommerce Store
VITE_APP_VERSION=1.0.0

# Feature Flags (comma-separated list or 'all' for all features)
# Example: VITE_ENABLE_FEATURES=products,cart,orders,payments
# Or: VITE_ENABLE_FEATURES=all
VITE_ENABLE_FEATURES=all

# Default Settings (currency is from API: GET /currencies/default)
VITE_DEFAULT_LANGUAGE=en

# Build Configuration
# Options: development, production
VITE_BUILD_MODE=development

# Optional: Analytics and Tracking
# VITE_ANALYTICS_ID=your-analytics-id
# VITE_GOOGLE_TAG_MANAGER_ID=your-gtm-id

# Optional: Payment Gateway Configuration
# VITE_STRIPE_PUBLIC_KEY=your-stripe-public-key
# VITE_PAYPAL_CLIENT_ID=your-paypal-client-id

# Optional: Image Upload Configuration
# VITE_IMAGE_UPLOAD_URL=your-image-upload-url
# VITE_IMAGE_UPLOAD_KEY=your-image-upload-key

# Optional: CDN Configuration
# VITE_CDN_URL=your-cdn-url

# Optional: Sentry Error Tracking
# VITE_SENTRY_DSN=your-sentry-dsn

# Optional: Feature Flags Service
# VITE_FEATURE_FLAGS_URL=your-feature-flags-service-url

# API Logging Configuration
# Enable/disable API request/response logging in terminal/console
# Options: true, false (default: true in development, false in production)
VITE_ENABLE_API_LOGGING=true

# API Log Level
# Options: 'none' (no logs), 'errors' (only errors), 'all' (all requests/responses)
# Default: 'all' in development, 'errors' in production
VITE_API_LOG_LEVEL=all
