# Development Environment Variables
# Copy this to .env.development and update with your development values

# API Configuration - Local backend URL
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Application Configuration
VITE_APP_NAME=Ecommerce Store (Dev)
VITE_APP_VERSION=1.0.0-dev

# Feature Flags - Enable all for development
VITE_ENABLE_FEATURES=all

# Default Settings
VITE_DEFAULT_LANGUAGE=en

# Build Configuration
VITE_BUILD_MODE=development

# API Logging Configuration
VITE_ENABLE_API_LOGGING=true
VITE_API_LOG_LEVEL=all

# Contact / WhatsApp (optional - used in Contact page, headers, footers)
# VITE_CONTACT_PHONE=+1234567890
# VITE_WHATSAPP_NUMBER=1234567890
