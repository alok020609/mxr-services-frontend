# Production Environment Variables
# Copy this to .env.production and update with your production values

# API Configuration - Update with your production backend URL
VITE_API_BASE_URL=https://api.yourdomain.com/api/v1

# Application Configuration
VITE_APP_NAME=MXR Services
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_FEATURES=all

# Default Settings
VITE_DEFAULT_LANGUAGE=en

# Build Configuration
VITE_BUILD_MODE=production

# API Logging Configuration
VITE_ENABLE_API_LOGGING=false
VITE_API_LOG_LEVEL=errors

# Contact / WhatsApp (optional - set for production)
# VITE_CONTACT_PHONE=+1234567890
# VITE_WHATSAPP_NUMBER=1234567890
